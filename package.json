{
  "name": "gumm",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "bunx --bun nuxi prepare",
    "db:generate": "bunx --bun nuxi db generate",
    "db:migrate": "bunx --bun drizzle-kit migrate --config back/drizzle.config.ts",
    "db:seed": "bun run scripts/seed.ts",
    "db:studio": "bunx --bun drizzle-kit studio --config back/drizzle.config.ts",
    "module:install": "bun run scripts/install-module.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@nuxt/icon": "1.15.0",
    "@tailwindcss/vite": "^4.2.1",
    "croner": "^10.0.1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.5",
    "nuxt": "^3.21.1",
    "nuxt-auth-utils": "^0.5.29",
    "redis": "^5.11.0",
    "tailwindcss": "^4.2.1",
    "tar": "^7.5.9",
    "vue": "latest",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^25.3.3",
    "drizzle-kit": "^0.31.9",
    "drizzle-zod": "^0.8.3"
  }
}
